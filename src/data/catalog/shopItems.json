  { "id": "balsa", "name": "Balsa", "category": "Transporte", "cost": "5 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~500 kg o 6 humanoides medianos. Tarda 1-3 días en construirse." },
  { "id": "barcaza", "name": "Barcaza", "category": "Transporte", "cost": "17.000 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~2.000 kg. Requiere 60 remeros; tripulación de 75 marineros y un capitán." },
  { "id": "barco-de-vela-grande", "name": "Barco de vela, grande", "category": "Transporte", "cost": "22.000 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~15.000 kg. 30-50 m de largo. Tripulación: 80 marineros y capitán; 3 mástiles y 2 catapultas." },
  { "id": "barco-de-vela-pequeno", "name": "Barco de vela, pequeño", "category": "Transporte", "cost": "7.000 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~5.000 kg. 20-30 m de largo; un solo mástil." },
  { "id": "barco-de-vela-para-transporte", "name": "Barco de vela para transporte", "category": "Transporte", "cost": "30.000 mo", "weight": null, "notes": "Transporte marítimo. Como el grande, pero diseñado para transportar tropas, monturas y equipo bélico." },
  { "id": "bote", "name": "Bote", "category": "Transporte", "cost": "3.000 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~1.500 kg. Se mueve con remos, pértigas o vela pequeña. +1.000 mo si dispone de techo." },
  { "id": "bote-salvavidas", "name": "Bote salvavidas", "category": "Transporte", "cost": "800 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~700 kg. Provisiones para que 10 humanos sobrevivan una semana." },
  { "id": "canoa", "name": "Canoa", "category": "Transporte", "cost": "55 mo", "weight": null, "notes": "Transporte marítimo. Pequeño bote de 20-30 kg; hasta ~300 kg de material." },
  { "id": "carro", "name": "Carro", "category": "Transporte", "cost": "100 mo", "weight": null, "notes": "Transporte terrestre. Tirado por 1-2 animales. Hasta 250 kg de carga. Velocidad ~20 m/asalto." },
  { "id": "carromato", "name": "Carromato", "category": "Transporte", "cost": "200 mo", "weight": null, "notes": "Transporte terrestre. Vehículo de 4 ruedas; 2 monturas acarrean ~800 kg, 4 monturas ~2.500 kg." },
  { "id": "galera-de-guerra", "name": "Galera de guerra", "category": "Transporte", "cost": "65.000 mo", "weight": null, "notes": "Transporte marítimo. Hasta ~3.000 kg. Requiere 300 galeotes; tripulación de 100 marineros y capitán. 3 catapultas y balistas pesadas." },
